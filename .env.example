# Whoop OAuth Credentials (Required)
# Register at https://developer-dashboard.whoop.com
WHOOP_CLIENT_ID=your-client-id
WHOOP_CLIENT_SECRET=your-client-secret

# Public URL of this server (Required for OAuth callback)
# Set this to your Railway/deployment URL
BASE_URL=http://localhost:3000

# Optional: Authentication token for MCP requests
# Generate a secure token with: openssl rand -hex 32
MCP_AUTH_TOKEN=your-secret-token-here

# Optional: Server port (default: 3000)
PORT=3000
